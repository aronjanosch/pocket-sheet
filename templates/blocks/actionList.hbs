{{!-- ActionListBlock: tappable item rows. Tap → useItem; long-press/right-click → openItem;
      optional glyph/img, prepared toggle (toggleItem), cost chip, and badge. --}}
<section class="ms-block ms-actionlist">
  {{#if hasTitle}}<h3 class="ms-list-title">{{title}}</h3>{{/if}}
  <ul class="ms-list">
    {{#each items}}
      <li class="ms-action-row" data-action="useItem" data-item-id="{{this.itemId}}"
          data-secondary-action="openItem">
        {{#if this.hasImg}}<img class="ms-action-img" src="{{this.img}}" alt="">{{/if}}
        {{#if this.hasGlyph}}<span class="ms-action-glyph">{{this.glyph}}</span>{{/if}}
        <span class="ms-action-text">
          <span class="ms-action-name">{{this.name}}</span>
          {{#if this.hasSub}}<span class="ms-action-sub">{{this.sub}}</span>{{/if}}
        </span>
        {{#if this.hasToggle}}
          <button type="button" class="ms-action-toggle{{#if this.toggleOn}} ms-on{{/if}}"
                  data-action="toggleItem" data-item-id="{{this.itemId}}"
                  aria-label="Toggle prepared"></button>
        {{/if}}
        {{#if this.hasCost}}<span class="ms-action-cost{{#if this.costMuted}} ms-cost-muted{{/if}}">{{this.cost}}</span>{{/if}}
        {{#if this.hasBadge}}<span class="ms-action-badge">{{this.badge}}</span>{{/if}}
      </li>
    {{/each}}
  </ul>
</section>
