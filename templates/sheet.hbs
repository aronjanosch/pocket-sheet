<div class="ms-root ms-state-{{state}}{{#if isIpad}} ms-ipad{{/if}}" style="{{themeStyle}}">

  {{#if isOk}}
    <div class="ms-flourish"></div>

    <header class="ms-identity">
      {{#if canSwitch}}
        <button type="button" class="ms-portrait-switch" data-action="switchActor"
                title="{{localize "MOBILE_SHEET.launcher.switchTitle"}}"
                aria-label="{{localize "MOBILE_SHEET.launcher.switchTitle"}}">
          {{#if identity.img}}
            <img class="ms-portrait" src="{{identity.img}}" alt="">
          {{else}}
            <div class="ms-portrait ms-portrait-mono">{{identity.initials}}</div>
          {{/if}}
          <span class="ms-switch-badge"><i class="fas fa-right-left"></i></span>
        </button>
      {{else}}
        {{#if identity.img}}
          <img class="ms-portrait" src="{{identity.img}}" alt="">
        {{else}}
          <div class="ms-portrait ms-portrait-mono">{{identity.initials}}</div>
        {{/if}}
      {{/if}}
      <div class="ms-id-text">
        <h2 class="ms-name">{{identity.name}}</h2>
        {{#if identity.subtitle}}<p class="ms-subtitle">{{identity.subtitle}}</p>{{/if}}
      </div>
      {{#if topStats.length}}
        <div class="ms-topstats">
          {{#each topStats}}
            <div class="ms-topstat">
              <span class="ms-topstat-label">{{this.label}}</span>
              <span class="ms-topstat-value{{#if this.accent}} ms-accented{{/if}}">{{this.value}}</span>
            </div>
          {{/each}}
        </div>
      {{/if}}
    </header>

    {{#if isIpad}}
      {{!-- ===== iPad: three panes (vitals rail · content · companion rail) ===== --}}
      <div class="ms-ipad-body">

        <aside class="ms-rail ms-rail-left">
          <div class="ms-rail-scroll">
            {{#each railBlocks}}{{> (lookup this "partial")}}{{/each}}
          </div>
          {{#if primary}}
            <div class="ms-tray ms-rail-tray">
              <button type="button" class="ms-primary" data-action="primary">
                <span class="ms-primary-label">{{primary.label}}</span>
                {{#if primary.sub}}<span class="ms-primary-sub">{{primary.sub}}</span>{{/if}}
              </button>
              <button type="button" class="ms-dice-btn" data-action="openDice"
                      title="{{localize "MOBILE_SHEET.dice.title"}}"
                      aria-label="{{localize "MOBILE_SHEET.dice.title"}}">⚅</button>
            </div>
          {{/if}}
        </aside>

        <section class="ms-center">
          {{#if tabs.length}}
            <nav class="ms-tabs">
              {{#each tabs}}
                <button type="button" class="ms-tab{{#if this.active}} ms-tab-active{{/if}}"
                        data-action="selectTab" data-tab="{{this.id}}">{{this.label}}</button>
              {{/each}}
            </nav>
          {{/if}}
          <div class="ms-body">
            {{#each blocks}}{{> (lookup this "partial")}}{{/each}}
          </div>
        </section>

        <aside class="ms-rail ms-rail-right{{#if companion.collapsed}} ms-rail-collapsed{{/if}}">
          <div class="ms-companion-bar">
            <div class="ms-companion-tabs" role="group">
              {{#each companion.tabs}}
                <button type="button" class="ms-companion-tab{{#if this.active}} ms-companion-tab-active{{/if}}"
                        data-action="selectCompanion" data-mode="{{this.id}}">
                  <span class="ms-mode-label">{{this.label}}</span>
                  {{#if this.badgeSlot}}<span class="ms-mode-badge{{#unless this.badge}} ms-mode-badge-hidden{{/unless}}">{{this.badge}}</span>{{/if}}
                </button>
              {{/each}}
            </div>
            <button type="button" class="ms-rail-collapse" data-action="toggleRight"
                    title="{{localize "MOBILE_SHEET.ipad.collapse"}}"
                    aria-label="{{localize "MOBILE_SHEET.ipad.collapse"}}">{{#if companion.collapsed}}«{{else}}»{{/if}}</button>
          </div>
          {{#if companion.isChat}}{{> (lookup . "chatPartial")}}{{/if}}
          {{#if companion.isJournal}}{{> (lookup . "journalPartial")}}{{/if}}
        </aside>

      </div>
    {{else}}
      {{!-- ===== phone: single column with a Sheet / Chat / Journal mode switch ===== --}}
      <nav class="ms-modes" role="group">
        {{#each modes}}
          <button type="button" class="ms-mode{{#if this.active}} ms-mode-active{{/if}}"
                  data-action="selectMode" data-mode="{{this.id}}">
            <span class="ms-mode-label">{{this.label}}</span>
            {{#if this.badgeSlot}}<span class="ms-mode-badge{{#unless this.badge}} ms-mode-badge-hidden{{/unless}}">{{this.badge}}</span>{{/if}}
          </button>
        {{/each}}
      </nav>

      {{#if isSheetMode}}
        <nav class="ms-tabs">
          {{#each tabs}}
            <button type="button" class="ms-tab{{#if this.active}} ms-tab-active{{/if}}"
                    data-action="selectTab" data-tab="{{this.id}}">{{this.label}}</button>
          {{/each}}
        </nav>

        <div class="ms-body">
          {{#each blocks}}{{> (lookup this "partial")}}{{/each}}
        </div>

        {{#if primary}}
          <div class="ms-tray">
            <button type="button" class="ms-primary" data-action="primary">
              <span class="ms-primary-label">{{primary.label}}</span>
              {{#if primary.sub}}<span class="ms-primary-sub">{{primary.sub}}</span>{{/if}}
            </button>
            <button type="button" class="ms-dice-btn" data-action="openDice"
                    title="{{localize "MOBILE_SHEET.dice.title"}}"
                    aria-label="{{localize "MOBILE_SHEET.dice.title"}}">⚅</button>
          </div>
        {{/if}}
      {{/if}}

      {{#if isChatMode}}{{> (lookup . "chatPartial")}}{{/if}}
      {{#if isJournalMode}}{{> (lookup . "journalPartial")}}{{/if}}
    {{/if}}
  {{/if}}

  {{#if isEmpty}}
    <header class="ms-identity">
      {{#if identity.img}}
        <img class="ms-portrait" src="{{identity.img}}" alt="">
      {{else}}
        <div class="ms-portrait ms-portrait-mono">{{identity.initials}}</div>
      {{/if}}
      <div class="ms-id-text"><h2 class="ms-name">{{identity.name}}</h2></div>
    </header>
    <div class="ms-message">
      <p>{{localize "MOBILE_SHEET.state.empty"}}</p>
    </div>
  {{/if}}

  {{#if isNoAdapter}}
    <div class="ms-message">
      <p>{{localize "MOBILE_SHEET.state.noAdapter"}}</p>
      <p class="ms-muted">{{localize "MOBILE_SHEET.state.noAdapterHint"}}</p>
    </div>
  {{/if}}

  {{#if isUnsupported}}
    <div class="ms-message">
      <p>{{localize "MOBILE_SHEET.state.unsupported"}}</p>
      {{#if reason}}<p class="ms-muted">{{reason}}</p>{{/if}}
    </div>
  {{/if}}

</div>
